{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "leetcode-scheduler",
  "version": "0.1.0",
  "identifier": "com.jaredvelasquez.leetcode-scheduler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "leetcode-scheduler",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "default": {
        "db-name": "leetcode_scheduler.db",
        "db-path": "$APP_LOCAL_DATA_DIR/leetcode_scheduler/leetcode_scheduler.db"
      },
      "permissions": ["sql:allow-execute", "sql:allow-read"]
    }
  }
}
